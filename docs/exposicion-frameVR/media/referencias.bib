@article{bhowmik2024virtual,
  title = {Virtual and augmented reality: Human sensory-perceptual requirements and trends for immersive spatial computing experiences},
  author = {Bhowmik, Achintya K.},
  journal = {Journal of the Society for Information Display},
  year = {2024},
  volume = {32},
  number = {8},
  pages = {567--582},
  doi = {10.1002/jsid.2001},
  url = {https://doi.org/10.1002/jsid.2001},
  abstract = {Building on several decades of research and development, the recent progress in virtual reality (VR) and augmented reality (AR) devices with spatial computing technologies marks a significant leap in human–computer interaction. The core objective of the VR and AR systems is to create convincing human sensory perceptions, thereby creating immersive and interactive experiences that bridge the gap between virtual and physical realities.}
}

@article{acevedo2024systematic,
  title = {A systematic review of immersive virtual reality in STEM education: Advantages and disadvantages on learning and user experience},
  author = {Acevedo, P. and Magana, A. J. and Benes, B. and Mousas, C.},
  journal = {IEEE Access},
  volume = {12},
  pages = {189359--189386},
  year = {2024},
  doi = {10.1109/ACCESS.2024.3489233},
  url = {https://doi.org/10.1109/ACCESS.2024.3489233},
  abstract = {Immersive virtual reality (IVR) is widely recognized as an innovative technology that enhances learning experiences. Due to innovations in virtual reality hardware and affordability in recent years, there is a higher chance that IVR will be adopted in educational settings. We proposed a conceptual framework to categorize the design and features of the IVR tools discussed in the papers, based on their levels of embodiment, immersion, and the type of learning they facilitate.}
}

@article{alkhatib2024technological,
  title = {Technological Features of Immersive Virtual Reality Systems for Upper Limb Stroke Rehabilitation: A Systematic Review},
  author = {Al-Khatib, A. and others},
  journal = {Sensors},
  volume = {24},
  number = {11},
  pages = {3546},
  year = {2024},
  doi = {10.3390/s24113546},
  url = {https://doi.org/10.3390/s24113546},
  abstract = {This systematic review evaluates the technological characteristics of IVR systems used in the rehabilitation of upper limb stroke patients. Various technical aspects such as game engines, programming languages, headsets, platforms, game genres, and technical evaluation were extracted. Unity 3D and C# are the primary tools for creating IVR apps, while the Oculus Quest is the most often used headset.}
}

@article{karutz2025immersive,
  title = {Immersive virtual reality in higher education: a systematic review of the scientific literature},
  author = {Karutz, R. and others},
  journal = {Virtual Reality},
  volume = {29},
  number = {64},
  year = {2025},
  doi = {10.1007/s10055-025-01136-x},
  url = {https://doi.org/10.1007/s10055-025-01136-x},
  abstract = {This article analyses the state-of-the-art of virtual reality (VR) in higher education and provides an overview of the VR literature and identifies the need for the definition of key terms. Thus, it introduces three types of VR according to immersion level: non-immersive, semi-immersive and immersive VR. The use of VR in education remains in its infancy but is steadily increasing due to the increased quality and availability of affordable devices.}
}

@article{elgazi2025immersive,
  title = {Immersive Technologies: Augmented Reality (AR) And Virtual Reality (VR)},
  author = {El Gazi, Safae and Ibrahimi, Ahmed},
  journal = {Proceedings of the E-Learning and Smart Engineering Systems (ELSES 2024)},
  publisher = {Atlantis Press},
  pages = {580--591},
  year = {2025},
  doi = {10.2991/978-2-38476-408-2_43},
  url = {https://doi.org/10.2991/978-2-38476-408-2_43},
  abstract = {This article examines how immersive technologies are changing and becoming more significant, with a particular emphasis on augmented reality (AR) and virtual reality (VR). It delves into the world of augmented reality, elucidating its fundamental ideas and showcasing the devices that are used, such as smartphones and AR glasses. The piece goes on to explore virtual reality (VR), going over the fundamental ideas and required hardware, including VR headsets.}
}

@article{tukur2025panoramic,
  title = {Panoramic imaging in immersive extended reality: a scoping review of technologies, applications, perceptual studies, and user experience challenges},
  author = {Tukur, M. and others},
  journal = {Frontiers in Virtual Reality},
  year = {2025},
  doi = {10.3389/frvir.2025.1622605},
  url = {https://doi.org/10.3389/frvir.2025.1622605},
  abstract = {Panoramic imaging plays a pivotal role in creating immersive experiences within Extended Reality (XR) environments, including Virtual Reality (VR), Augmented Reality (AR), and Mixed Reality (MR). The analysis explores the level of user interaction and immersion supported by these systems, specifically in terms of degrees of freedom (DoF). A majority of the studies (56.41%) offer 3DoF, which allows users to look around within a static position, while only 35.90% provide 6DoF, enabling full movement in space.}
}

@inproceedings{burnett2025evaluation,
  title = {An evaluation of headset vs desktop use for accessing virtual worlds in a Higher Education context},
  author = {Burnett, Gary},
  booktitle = {Immersive Learning Research Network (iLRN 2024)},
  series = {Communications in Computer and Information Science},
  volume = {2271},
  pages = {167--176},
  publisher = {Springer},
  year = {2025},
  doi = {10.1007/978-3-031-80475-5_12},
  url = {https://doi.org/10.1007/978-3-031-80475-5_12},
  abstract = {A fundamental research question concerns the role of immersion itself – should students wear virtual reality headsets for full benefits to be realised, or will traditional desktop/laptop computers suffice? Students overwhelmingly preferred using a headset to access interactive seminars, citing advantages of enhanced focus, confidence, and engagement. Nevertheless, sickness was a considerable problem for a minority of students.}
}